{
  "_comment": "Keybindings mimic the user's Neovim config (leader = comma). They are layered on top of Fresh's built-in 'macos' keymap and are resolved BEFORE the vi_mode plugin's bindings, so they work in vi NORMAL mode and intentionally shadow vi keys (comma, H, L) exactly as the Neovim config does. Vi motions (hjkl, w/b/e, dd, etc.) come from the bundled vi_mode plugin, enabled via plugins.vi_mode.settings.autoStart below.",
  "keybindings": [
    {
      "comment": "Ctrl+N -> toggle file tree (nvim: <C-n> Neotree toggle)",
      "key": "n",
      "modifiers": ["ctrl"],
      "action": "toggle_file_explorer",
      "when": "normal"
    },
    {
      "comment": "Ctrl+N -> toggle file tree, also when the explorer itself is focused",
      "key": "n",
      "modifiers": ["ctrl"],
      "action": "toggle_file_explorer",
      "when": "file_explorer"
    },
    {
      "comment": "Ctrl+H -> focus previous split (nvim: <C-h> go to left window)",
      "key": "h",
      "modifiers": ["ctrl"],
      "action": "prev_split",
      "when": "normal"
    },
    {
      "comment": "Ctrl+L -> focus next split (nvim: <C-l> go to right window)",
      "key": "l",
      "modifiers": ["ctrl"],
      "action": "next_split",
      "when": "normal"
    },
    {
      "comment": "Ctrl+K -> focus previous split (nvim: <C-k> upper window; Fresh splits cycle, no directional focus)",
      "key": "k",
      "modifiers": ["ctrl"],
      "action": "prev_split",
      "when": "normal"
    },
    {
      "comment": "Ctrl+J -> focus next split (nvim: <C-j> lower window; Fresh splits cycle, no directional focus)",
      "key": "j",
      "modifiers": ["ctrl"],
      "action": "next_split",
      "when": "normal"
    },
    {
      "comment": "Shift+H -> previous buffer (nvim cheatsheet; shadows vi H = top of screen)",
      "key": "h",
      "modifiers": ["shift"],
      "action": "prev_buffer",
      "when": "normal"
    },
    {
      "comment": "Shift+L -> next buffer (nvim cheatsheet; shadows vi L = bottom of screen)",
      "key": "l",
      "modifiers": ["shift"],
      "action": "next_buffer",
      "when": "normal"
    },
    {
      "comment": "[b -> previous buffer (nvim cheatsheet)",
      "keys": [{ "key": "[", "modifiers": [] }, { "key": "b", "modifiers": [] }],
      "action": "prev_buffer",
      "when": "normal"
    },
    {
      "comment": "]b -> next buffer (nvim cheatsheet)",
      "keys": [{ "key": "]", "modifiers": [] }, { "key": "b", "modifiers": [] }],
      "action": "next_buffer",
      "when": "normal"
    },
    {
      "comment": "Alt+Up -> add cursor above (nvim cheatsheet multicursor)",
      "key": "Up",
      "modifiers": ["alt"],
      "action": "add_cursor_above",
      "when": "normal"
    },
    {
      "comment": "Alt+Down -> add cursor below (nvim cheatsheet multicursor)",
      "key": "Down",
      "modifiers": ["alt"],
      "action": "add_cursor_below",
      "when": "normal"
    },
    {
      "comment": "Ctrl+/ -> toggle comment (nvim uses gcc; bound to Ctrl+/ to avoid shadowing vi g-motions like gg)",
      "key": "/",
      "modifiers": ["ctrl"],
      "action": "toggle_comment",
      "when": "normal"
    },
    {
      "comment": "<leader>e -> focus file tree (nvim: <leader>e Neotree focus). Leader = comma.",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "e", "modifiers": [] }],
      "action": "focus_file_explorer",
      "when": "normal"
    },
    {
      "comment": "<leader>ff -> find files (nvim: Telescope find_files)",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "f", "modifiers": [] }, { "key": "f", "modifiers": [] }],
      "action": "quick_open_files",
      "when": "normal"
    },
    {
      "comment": "<leader>fg -> live grep (nvim: Telescope live_grep)",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "f", "modifiers": [] }, { "key": "g", "modifiers": [] }],
      "action": "open_live_grep",
      "when": "normal"
    },
    {
      "comment": "<leader>fb -> open buffers (nvim: Telescope buffers)",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "f", "modifiers": [] }, { "key": "b", "modifiers": [] }],
      "action": "quick_open_buffers",
      "when": "normal"
    },
    {
      "comment": "<leader>fo -> recent files (nvim: Telescope oldfiles; mapped to Fresh quick_open which surfaces recents)",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "f", "modifiers": [] }, { "key": "o", "modifiers": [] }],
      "action": "quick_open",
      "when": "normal"
    },
    {
      "comment": "<leader>sr -> search & replace (nvim: Grug-far)",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "s", "modifiers": [] }, { "key": "r", "modifiers": [] }],
      "action": "query_replace",
      "when": "normal"
    },
    {
      "comment": "<leader>gg -> open terminal (nvim: lazygit via snacks). Fresh has no git UI; run lazygit/git in this terminal.",
      "keys": [{ "key": ",", "modifiers": [] }, { "key": "g", "modifiers": [] }, { "key": "g", "modifiers": [] }],
      "action": "open_terminal_in_dock",
      "when": "normal"
    }
  ],
